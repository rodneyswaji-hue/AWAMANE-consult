---
interface Props {
  icon: string;
  class?: string;
}

const { icon, class: className = 'w-8 h-8' } = Astro.props;
---

{icon === 'leaf' && (
  <svg class={className} viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M6 26 C 6 14, 14 6, 26 6 C 26 18, 18 26, 6 26 Z" />
    <path d="M6 26 L 20 12" />
    <path d="M12 20 L 16 20 M 14 16 L 16 18" opacity="0.6" />
  </svg>
)}

{icon === 'cow' && (
  <svg class={className} viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M10 14 C 10 10, 12 8, 16 8 C 20 8, 22 10, 22 14 L 22 18 C 22 22, 20 24, 16 24 C 12 24, 10 22, 10 18 Z" />
    <path d="M8 10 L 10 12 M 24 10 L 22 12" />
    <circle cx="13" cy="14" r="0.8" fill="currentColor" />
    <circle cx="19" cy="14" r="0.8" fill="currentColor" />
    <path d="M14 19 L 18 19" />
    <path d="M12 24 L 12 28 M 20 24 L 20 28" />
  </svg>
)}

{icon === 'water' && (
  <svg class={className} viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M16 4 C 16 4, 8 14, 8 20 A 8 8 0 0 0 24 20 C 24 14, 16 4, 16 4 Z" />
    <path d="M12 20 A 4 4 0 0 0 16 24" opacity="0.5" />
  </svg>
)}

{icon === 'graduation' && (
  <svg class={className} viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M4 12 L 16 6 L 28 12 L 16 18 Z" />
    <path d="M9 15 L 9 22 C 9 24, 12 26, 16 26 C 20 26, 23 24, 23 15" />
    <path d="M28 12 L 28 20" />
    <circle cx="28" cy="22" r="1.5" fill="currentColor" />
  </svg>
)}

{icon === 'sun' && (
  <svg class={className} viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="16" cy="16" r="5" />
    <path d="M16 4 L 16 7 M 16 25 L 16 28 M 4 16 L 7 16 M 25 16 L 28 16 M 7.5 7.5 L 9.5 9.5 M 22.5 22.5 L 24.5 24.5 M 7.5 24.5 L 9.5 22.5 M 22.5 9.5 L 24.5 7.5" />
  </svg>
)}

{icon === 'hands' && (
  <svg class={className} viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M4 20 C 4 16, 6 14, 10 14 L 10 10 C 10 8, 12 8, 12 10 L 12 15 L 14 15 L 14 8 C 14 6, 16 6, 16 8 L 16 16 L 18 16 L 18 10 C 18 8, 20 8, 20 10 L 20 17 L 22 17 L 22 13 C 22 11, 24 11, 24 13 L 24 20 C 24 24, 20 26, 16 26 C 12 26, 8 24, 6 22" />
  </svg>
)}
