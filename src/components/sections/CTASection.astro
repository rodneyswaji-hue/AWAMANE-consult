---
interface Props {
  title?: string;
  subtitle?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  title = "Ready to put research to work on your farm?",
  subtitle = "Whether you're a smallholder, a commercial operation, or an organization running a programme — we'd love to hear from you.",
  primaryLabel = 'Book a Consultation',
  primaryHref = '/contact',
  secondaryLabel = 'Explore Services',
  secondaryHref = '/services',
} = Astro.props;
---

<section class="section">
  <div class="container-x">
    <div class="relative rounded-[var(--radius-xl)] overflow-hidden surface-forest grain p-10 md:p-16 lg:p-20">
      <!-- Decorative leaf shapes -->
      <svg class="absolute top-0 right-0 w-64 h-64 text-[var(--color-forest-600)] opacity-40 -translate-y-1/4 translate-x-1/4" viewBox="0 0 200 200" aria-hidden="true">
        <path d="M20 180 C 20 80, 80 20, 180 20 C 180 120, 120 180, 20 180 Z" fill="currentColor" />
      </svg>
      <svg class="absolute bottom-0 left-0 w-40 h-40 text-[var(--color-earth-500)] opacity-20 translate-y-1/3 -translate-x-1/4" viewBox="0 0 200 200" aria-hidden="true">
        <path d="M20 180 C 20 80, 80 20, 180 20 C 180 120, 120 180, 20 180 Z" fill="currentColor" />
      </svg>

      <div class="relative max-w-3xl">
        <div class="eyebrow !text-[var(--color-earth-300)]">
          Get started
        </div>
        <h2 class="mt-6 text-[var(--color-cream)]">
          {title}
        </h2>
        {subtitle && (
          <p class="mt-6 text-lg text-[var(--color-cream)]/85 leading-relaxed">
            {subtitle}
          </p>
        )}
        <div class="mt-10 flex flex-wrap gap-4">
          <a href={primaryHref} class="btn btn-earth">{primaryLabel}</a>
          <a
            href={secondaryHref}
            class="btn border border-[var(--color-cream)]/30 text-[var(--color-cream)] hover:bg-[var(--color-cream)]/10"
          >
            {secondaryLabel}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
