---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  image?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, subtitle, image, align = 'left' } = Astro.props;
---

<section class="relative overflow-hidden pt-16 md:pt-24 pb-16 md:pb-20 surface-paper grain">
  <!-- Decorative elements -->
  <div class="absolute top-0 right-0 w-[40rem] h-[40rem] rounded-full bg-gradient-to-br from-[var(--color-forest-100)] to-transparent opacity-40 -translate-y-1/3 translate-x-1/4 blur-3xl pointer-events-none" aria-hidden="true"></div>
  <div class="absolute bottom-0 left-0 w-[30rem] h-[30rem] rounded-full bg-gradient-to-tr from-[var(--color-earth-100)] to-transparent opacity-50 translate-y-1/2 -translate-x-1/4 blur-3xl pointer-events-none" aria-hidden="true"></div>

  <div class="relative container-x">
    <div class:list={[
      'max-w-4xl',
      align === 'center' ? 'mx-auto text-center' : ''
    ]}>
      {eyebrow && (
        <div class="mb-6 animate-fade-up">
          <div class="eyebrow">{eyebrow}</div>
        </div>
      )}
      <h1 class="animate-fade-up" style="transition-delay: 60ms">
        {title}
      </h1>
      {subtitle && (
        <p class="mt-6 text-lg md:text-xl text-[var(--color-charcoal)]/80 max-w-2xl leading-relaxed animate-fade-up" style="transition-delay: 120ms">
          {subtitle}
        </p>
      )}
    </div>
  </div>

  {image && (
    <div class="relative container-x mt-12 md:mt-16">
      <div class="relative rounded-[var(--radius-xl)] overflow-hidden aspect-[21/9] shadow-[var(--shadow-lift)]">
        <img src={image} alt="" class="absolute inset-0 w-full h-full object-cover animate-slow-zoom" />
      </div>
    </div>
  )}
</section>
