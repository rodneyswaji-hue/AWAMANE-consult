---
interface Props {
  title: string;
  summary: string;
  location?: string;
  category: string;
  coverImage: string;
  href: string;
  featured?: boolean;
  index?: number;
}

const { title, summary, location, category, coverImage, href, featured = false, index = 0 } = Astro.props;

const categoryLabels: Record<string, string> = {
  crops: 'Crops',
  livestock: 'Livestock',
  water: 'Water & Land',
  training: 'Training',
  community: 'Community',
};
---

<a
  href={href}
  class:list={[
    'group relative block overflow-hidden rounded-[var(--radius-xl)] bg-white shadow-[var(--shadow-soft)] hover:shadow-[var(--shadow-lift)] transition-all duration-500',
    featured ? 'md:col-span-2' : ''
  ]}
  style={`transition-delay: ${index * 80}ms`}
>
  <div class:list={[
    'relative overflow-hidden',
    featured ? 'aspect-[16/9]' : 'aspect-[4/3]'
  ]}>
    <img
      src={coverImage}
      alt={title}
      class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1.2s] ease-out group-hover:scale-[1.08]"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-ink)]/85 via-[var(--color-ink)]/30 to-transparent"></div>

    <!-- Category pill -->
    <div class="absolute top-4 left-4">
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-[var(--color-cream)]/95 text-[var(--color-forest-700)] backdrop-blur">
        {categoryLabels[category] ?? category}
      </span>
    </div>

    <!-- Overlay text -->
    <div class="absolute inset-x-0 bottom-0 p-6 md:p-8 text-[var(--color-cream)]">
      {location && (
        <div class="text-xs tracking-[0.15em] uppercase text-[var(--color-earth-200)] mb-2">
          {location}
        </div>
      )}
      <h3 class="text-[var(--color-cream)] text-xl md:text-2xl leading-tight">
        {title}
      </h3>
      <p class="mt-3 text-sm md:text-base text-[var(--color-cream)]/85 leading-relaxed line-clamp-2 md:line-clamp-3">
        {summary}
      </p>
      <div class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-[var(--color-earth-300)] opacity-0 group-hover:opacity-100 -translate-y-1 group-hover:translate-y-0 transition-all duration-300">
        Read more
        <span>→</span>
      </div>
    </div>
  </div>
</a>
