---
import { SITE } from '../../config';

const currentYear = new Date().getFullYear();
---

<footer class="relative mt-20 bg-[var(--color-forest-800)] text-[var(--color-cream)] overflow-hidden">
  <!-- Decorative top wave -->
  <svg class="absolute top-0 left-0 w-full h-8 -translate-y-full" viewBox="0 0 1440 60" preserveAspectRatio="none" aria-hidden="true">
    <path d="M0 60 C 240 0, 480 60, 720 30 S 1200 0, 1440 40 L 1440 60 Z" fill="var(--color-forest-800)" />
  </svg>

  <div class="container-x py-16 md:py-20 relative">
    <div class="grid gap-12 lg:grid-cols-12">
      <!-- Brand column -->
      <div class="lg:col-span-5">
        <div class="flex items-center gap-3 mb-5">
          <img src="/logo.png" alt="" width="56" height="56" class="w-14 h-14 object-contain brightness-0 invert opacity-90" />
          <div>
            <div class="font-[var(--font-display)] text-2xl">Awamane Consult</div>
            <div class="text-xs tracking-[0.2em] uppercase text-[var(--color-earth-200)] mt-1">Environment · Community · Sustainability</div>
          </div>
        </div>
        <p class="text-[var(--color-cream)]/80 leading-relaxed max-w-md">
          Evidence-based agricultural consultancy for Kenya — bringing decades of academic and field expertise to farmers, communities, and organizations.
        </p>
        <div class="mt-8 flex items-center gap-3">
          <a
            href={SITE.linkedin}
            target="_blank"
            rel="noopener"
            aria-label="LinkedIn"
            class="w-10 h-10 rounded-full border border-[var(--color-cream)]/20 flex items-center justify-center hover:bg-[var(--color-earth-400)] hover:border-transparent hover:text-[var(--color-ink)] transition-all duration-200"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div class="lg:col-span-2">
        <h4 class="text-sm font-semibold tracking-[0.15em] uppercase text-[var(--color-earth-200)] mb-5">Explore</h4>
        <ul class="flex flex-col gap-3 text-sm text-[var(--color-cream)]/80">
          <li><a href="/about" class="hover:text-[var(--color-earth-300)] transition-colors">About</a></li>
          <li><a href="/services" class="hover:text-[var(--color-earth-300)] transition-colors">Services</a></li>
          <li><a href="/training" class="hover:text-[var(--color-earth-300)] transition-colors">Training</a></li>
          <li><a href="/projects" class="hover:text-[var(--color-earth-300)] transition-colors">Projects</a></li>
          <li><a href="/blog" class="hover:text-[var(--color-earth-300)] transition-colors">Blog</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div class="lg:col-span-2">
        <h4 class="text-sm font-semibold tracking-[0.15em] uppercase text-[var(--color-earth-200)] mb-5">Services</h4>
        <ul class="flex flex-col gap-3 text-sm text-[var(--color-cream)]/80">
          <li><a href="/services/crops-and-soil" class="hover:text-[var(--color-earth-300)] transition-colors">Crops & Soil</a></li>
          <li><a href="/services/livestock" class="hover:text-[var(--color-earth-300)] transition-colors">Livestock</a></li>
          <li><a href="/services/water-and-land-management" class="hover:text-[var(--color-earth-300)] transition-colors">Water & Land</a></li>
          <li><a href="/training" class="hover:text-[var(--color-earth-300)] transition-colors">Training</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="lg:col-span-3">
        <h4 class="text-sm font-semibold tracking-[0.15em] uppercase text-[var(--color-earth-200)] mb-5">Get in touch</h4>
        <ul class="flex flex-col gap-4 text-sm text-[var(--color-cream)]/85">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-[var(--color-earth-300)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 2a8 8 0 018 8c0 6-8 12-8 12S4 16 4 10a8 8 0 018-8z" />
              <circle cx="12" cy="10" r="3" fill="none" stroke-width="2" />
            </svg>
            <span>{SITE.location}</span>
          </li>
          <li>
            <a href={SITE.phoneHref} class="flex items-start gap-3 hover:text-[var(--color-earth-300)] transition-colors">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-[var(--color-earth-300)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" d="M3 5a2 2 0 012-2h2l2 5-2 1a11 11 0 005 5l1-2 5 2v2a2 2 0 01-2 2A16 16 0 013 5z" />
              </svg>
              <span>{SITE.phone}</span>
            </a>
          </li>
          <li>
            <a href={SITE.emailHref} class="flex items-start gap-3 hover:text-[var(--color-earth-300)] transition-colors">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-[var(--color-earth-300)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" d="M3 8l9 6 9-6M5 6h14a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2z" />
              </svg>
              <span>{SITE.email}</span>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-16 pt-8 border-t border-[var(--color-cream)]/10 flex flex-col md:flex-row md:items-center justify-between gap-4 text-xs text-[var(--color-cream)]/60">
      <div>
        © {currentYear} {SITE.name}. All rights reserved.
      </div>
      <div class="flex items-center gap-6">
        <a href="/contact" class="hover:text-[var(--color-earth-300)] transition-colors">Contact</a>
        <span class="font-[var(--font-display)] italic text-[var(--color-earth-300)]/70">
          Rooted in research · Grown in the field
        </span>
      </div>
    </div>
  </div>
</footer>
