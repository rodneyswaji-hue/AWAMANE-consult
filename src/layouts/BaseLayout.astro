---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { SITE } from '../config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
  /** Structured data to inject (JSON-LD). Pass null to skip. */
  structuredData?: Record<string, unknown> | null;
}

const {
  title,
  description = SITE.description,
  image = '/logo.png',
  noIndex = false,
  structuredData,
} = Astro.props;

const pageTitle = title ? `${title} — ${SITE.name}` : `${SITE.name} — ${SITE.tagline}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? SITE.url).toString();
const ogImage = new URL(image, Astro.site ?? SITE.url).toString();

// Default organization JSON-LD (used on every page unless overridden)
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.name,
  url: SITE.url,
  logo: `${SITE.url}/logo.png`,
  description: SITE.description,
  address: {
    '@type': 'PostalAddress',
    addressLocality: SITE.locality,
    addressRegion: SITE.region,
    addressCountry: SITE.country,
  },
  telephone: SITE.phone,
  email: SITE.email,
  founder: {
    '@type': 'Person',
    name: 'Prof. Titus Ikusya Kanui',
    jobTitle: 'Professor of Animal Science',
    sameAs: [SITE.linkedin],
  },
};

const finalStructuredData = structuredData === null ? null : (structuredData ?? orgSchema);
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="theme-color" content="#2d5f2d" />

    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Primary meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="en_KE" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts: Fraunces (display) + Inter (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,300..700,0..100&family=Inter:wght@300;400;500;600;700&display=swap"
    />

    <!-- Structured data -->
    {finalStructuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(finalStructuredData)} />
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-[var(--color-forest-600)] focus:text-[var(--color-cream)] focus:px-4 focus:py-2 focus:rounded-lg">
      Skip to content
    </a>

    <Header currentPath={currentPath} />

    <main id="main" class="flex-1">
      <slot />
    </main>

    <Footer />

    <script is:inline>
      // Scroll-reveal: animate fade-up / fade-in / stagger-children only when they enter the viewport.
      // Elements default to opacity: 1 in CSS — so without JS or before this runs, everything is visible.
      (function () {
        if (typeof window === 'undefined') return;

        const selector = '.animate-fade-up, .animate-fade-in, .stagger-children > *';
        const targets = document.querySelectorAll(selector);
        if (!targets.length) return;

        // Respect user's reduced-motion preference
        const prefersReduced =
          window.matchMedia &&
          window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReduced) return;

        // If IntersectionObserver is missing, bail — elements stay visible.
        if (!('IntersectionObserver' in window)) return;

        // Mark elements as "about to animate" — CSS hides them
        targets.forEach((el) => el.setAttribute('data-reveal', ''));

        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.setAttribute('data-revealed', '');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
        );

        targets.forEach((el) => io.observe(el));

        // Fallback: if something is already in the viewport on load (top of page),
        // reveal it on the next frame so it animates in nicely.
        requestAnimationFrame(() => {
          targets.forEach((el) => {
            const rect = el.getBoundingClientRect();
            if (rect.top < window.innerHeight && rect.bottom > 0) {
              el.setAttribute('data-revealed', '');
              io.unobserve(el);
            }
          });
        });
      })();
    </script>
  </body>
</html>
