---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/sections/CTASection.astro';
import Eyebrow from '../../components/ui/Eyebrow.astro';
import ProjectCard from '../../components/sections/ProjectCard.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const allProjects = await getCollection('projects');
const relatedProjects = allProjects
  .filter((p) => p.id !== project.id && p.data.category === project.data.category)
  .slice(0, 2);

const categoryLabels: Record<string, string> = {
  crops: 'Crops',
  livestock: 'Livestock',
  water: 'Water & Land',
  training: 'Training',
  community: 'Community',
};
---

<BaseLayout
  title={project.data.title}
  description={project.data.summary}
  image={project.data.coverImage}
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="relative aspect-[21/9] md:aspect-[21/8] min-h-[26rem]">
      <img
        src={project.data.coverImage}
        alt={project.data.title}
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-ink)]/85 via-[var(--color-ink)]/50 to-transparent"></div>

      <div class="absolute inset-0 flex items-end">
        <div class="container-x pb-12 md:pb-20 text-[var(--color-cream)]">
          <a href="/projects" class="inline-flex items-center gap-2 text-sm text-[var(--color-cream)]/80 hover:text-[var(--color-earth-300)] transition-colors mb-6">
            <span>←</span> All projects
          </a>

          <div class="flex flex-wrap items-center gap-3 mb-5">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-[var(--color-cream)]/95 text-[var(--color-forest-700)]">
              {categoryLabels[project.data.category]}
            </span>
            {project.data.location && (
              <span class="text-xs tracking-[0.15em] uppercase text-[var(--color-earth-200)]">
                {project.data.location}
              </span>
            )}
            {project.data.year && (
              <span class="text-xs tracking-[0.15em] uppercase text-[var(--color-earth-200)]">
                · {project.data.year}
              </span>
            )}
          </div>

          <h1 class="text-[var(--color-cream)] max-w-4xl">{project.data.title}</h1>
        </div>
      </div>
    </div>
  </section>

  <!-- Body -->
  <section class="section">
    <div class="container-x">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
        <div class="lg:col-span-8">
          <p class="text-xl md:text-2xl text-[var(--color-charcoal)] font-[var(--font-display)] italic leading-relaxed border-l-4 border-[var(--color-earth-400)] pl-6 mb-10">
            {project.data.summary}
          </p>

          <div class="prose-awamane text-lg text-[var(--color-charcoal)]/85 leading-relaxed [&>p]:mb-6">
            <Content />
          </div>
        </div>

        <aside class="lg:col-span-4">
          <div class="sticky top-28 space-y-6">
            <div class="p-7 rounded-[var(--radius-xl)] bg-white border border-[var(--color-sand)]/60">
              <div class="text-xs font-semibold tracking-[0.15em] uppercase text-[var(--color-forest-700)] mb-5">
                Project details
              </div>
              <dl class="space-y-4 text-sm">
                <div class="pb-4 border-b border-[var(--color-sand)]/60">
                  <dt class="text-[var(--color-charcoal)]/60 text-xs uppercase tracking-wider mb-1">Category</dt>
                  <dd class="font-medium text-[var(--color-ink)]">{categoryLabels[project.data.category]}</dd>
                </div>
                {project.data.location && (
                  <div class="pb-4 border-b border-[var(--color-sand)]/60">
                    <dt class="text-[var(--color-charcoal)]/60 text-xs uppercase tracking-wider mb-1">Location</dt>
                    <dd class="font-medium text-[var(--color-ink)]">{project.data.location}</dd>
                  </div>
                )}
                {project.data.year && (
                  <div class="pb-4 border-b border-[var(--color-sand)]/60">
                    <dt class="text-[var(--color-charcoal)]/60 text-xs uppercase tracking-wider mb-1">Year</dt>
                    <dd class="font-medium text-[var(--color-ink)]">{project.data.year}</dd>
                  </div>
                )}
              </dl>
            </div>

            <div class="p-7 rounded-[var(--radius-xl)] surface-forest grain">
              <h3 class="text-[var(--color-cream)] text-lg">Interested in similar work?</h3>
              <p class="mt-3 text-sm text-[var(--color-cream)]/85 leading-relaxed">
                We partner with organizations on projects of every size. Let's talk.
              </p>
              <a href="/contact" class="btn btn-earth w-full mt-5 text-sm">Start a conversation</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Related -->
  {relatedProjects.length > 0 && (
    <section class="section bg-white border-t border-[var(--color-sand)]/50">
      <div class="container-x">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10">
          <div>
            <Eyebrow>More from this area</Eyebrow>
            <h2 class="mt-5">Related projects</h2>
          </div>
          <a href="/projects" class="link-arrow">View all</a>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          {relatedProjects.map((p, i) => (
            <ProjectCard
              title={p.data.title}
              summary={p.data.summary}
              location={p.data.location}
              category={p.data.category}
              coverImage={p.data.coverImage}
              href={`/projects/${p.id}`}
              index={i}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <CTASection />
</BaseLayout>
