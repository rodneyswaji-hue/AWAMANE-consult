---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/sections/PageHeader.astro';
import ContactForm from '../components/sections/ContactForm.tsx';
import Eyebrow from '../components/ui/Eyebrow.astro';
import { SITE } from '../config';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Awamane Consult Ltd. Based in Kyevaluki, Machakos County, Kenya — serving farmers and organizations across the country."
>
  <PageHeader
    eyebrow="Get in touch"
    title="Let's start a conversation."
    subtitle="Whether you're planning a single farm visit or a multi-year programme, we'd love to hear from you. We typically respond within one working day."
  />

  <section class="section">
    <div class="container-x">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
        <!-- Form -->
        <div class="lg:col-span-7">
          <div class="p-8 md:p-10 rounded-[var(--radius-xl)] bg-white shadow-[var(--shadow-soft)] border border-[var(--color-sand)]/60">
            <Eyebrow>Send us a message</Eyebrow>
            <h2 class="mt-4 text-3xl">How can we help?</h2>
            <p class="mt-3 text-[var(--color-charcoal)]/75">
              Fill in the form below and one of our team will get back to you.
            </p>

            <div class="mt-10">
              <ContactForm client:load />
            </div>
          </div>
        </div>

        <!-- Info -->
        <aside class="lg:col-span-5">
          <div class="sticky top-28 space-y-6">
            <!-- Direct channels -->
            <div class="p-8 rounded-[var(--radius-xl)] surface-forest grain">
              <h3 class="text-[var(--color-cream)] text-2xl">Direct channels</h3>
              <p class="mt-3 text-sm text-[var(--color-cream)]/85 leading-relaxed">
                Prefer to reach out directly? Here's how.
              </p>

              <div class="mt-8 space-y-6">
                <a href={SITE.phoneHref} class="flex items-start gap-4 group">
                  <div class="w-10 h-10 rounded-lg bg-[var(--color-cream)]/10 text-[var(--color-earth-300)] flex items-center justify-center shrink-0 group-hover:bg-[var(--color-earth-400)] group-hover:text-[var(--color-ink)] transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" d="M3 5a2 2 0 012-2h2l2 5-2 1a11 11 0 005 5l1-2 5 2v2a2 2 0 01-2 2A16 16 0 013 5z" />
                    </svg>
                  </div>
                  <div>
                    <div class="text-xs uppercase tracking-[0.15em] text-[var(--color-earth-200)]">Phone</div>
                    <div class="mt-1 font-medium text-[var(--color-cream)] group-hover:text-[var(--color-earth-300)] transition-colors">
                      {SITE.phone}
                    </div>
                  </div>
                </a>

                <a href={SITE.emailHref} class="flex items-start gap-4 group">
                  <div class="w-10 h-10 rounded-lg bg-[var(--color-cream)]/10 text-[var(--color-earth-300)] flex items-center justify-center shrink-0 group-hover:bg-[var(--color-earth-400)] group-hover:text-[var(--color-ink)] transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" d="M3 8l9 6 9-6M5 6h14a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2z" />
                    </svg>
                  </div>
                  <div>
                    <div class="text-xs uppercase tracking-[0.15em] text-[var(--color-earth-200)]">Email</div>
                    <div class="mt-1 font-medium text-[var(--color-cream)] group-hover:text-[var(--color-earth-300)] transition-colors break-all">
                      {SITE.email}
                    </div>
                  </div>
                </a>

                <a href={SITE.linkedin} target="_blank" rel="noopener" class="flex items-start gap-4 group">
                  <div class="w-10 h-10 rounded-lg bg-[var(--color-cream)]/10 text-[var(--color-earth-300)] flex items-center justify-center shrink-0 group-hover:bg-[var(--color-earth-400)] group-hover:text-[var(--color-ink)] transition-colors">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z" />
                    </svg>
                  </div>
                  <div>
                    <div class="text-xs uppercase tracking-[0.15em] text-[var(--color-earth-200)]">LinkedIn</div>
                    <div class="mt-1 font-medium text-[var(--color-cream)] group-hover:text-[var(--color-earth-300)] transition-colors">
                      Prof. Titus Kanui
                    </div>
                  </div>
                </a>
              </div>
            </div>

            <!-- Location -->
            <div class="p-8 rounded-[var(--radius-xl)] bg-white border border-[var(--color-sand)]/60">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-[var(--color-earth-100)] text-[var(--color-earth-600)] flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 2a8 8 0 018 8c0 6-8 12-8 12S4 16 4 10a8 8 0 018-8z" />
                    <circle cx="12" cy="10" r="2.5" fill="none" stroke-width="2" />
                  </svg>
                </div>
                <div class="flex-1">
                  <div class="text-xs uppercase tracking-[0.15em] text-[var(--color-forest-700)] font-semibold">
                    Location
                  </div>
                  <div class="mt-2 font-medium text-[var(--color-ink)]">{SITE.location}</div>
                  <p class="mt-3 text-sm text-[var(--color-charcoal)]/70 leading-relaxed">
                    We serve farmers and organizations across Kenya, with most field work concentrated in Eastern Kenya — Machakos, Makueni, Kitui, and neighbouring counties.
                  </p>
                  <p class="mt-3 text-xs text-[var(--color-charcoal)]/60 italic">
                    A Nairobi office is in the works.
                  </p>
                </div>
              </div>
            </div>

            <!-- Response time -->
            <div class="p-6 rounded-[var(--radius-lg)] bg-[var(--color-earth-50)] border border-[var(--color-earth-200)]">
              <div class="flex items-center gap-3 text-sm text-[var(--color-earth-700)]">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <circle cx="12" cy="12" r="9" />
                  <path stroke-linecap="round" d="M12 7v5l3 2" />
                </svg>
                <span class="font-medium">We respond within one working day.</span>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
